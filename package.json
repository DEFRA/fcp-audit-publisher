{
  "name": "@defra/fcp-audit-publisher",
  "version": "0.4.0",
  "description": "An library to validate and/or publish FCP Audit events to the FCP Audit service.",
  "main": "./dist/index.cjs",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "build": "tsup",
    "test": "npm run build && vitest run --coverage",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DEFRA/fcp-audit-publisher.git"
  },
  "keywords": [
    "fcp-audit-publisher",
    "defra",
    "fcp",
    "audit"
  ],
  "author": "Defra DDTS",
  "contributors": [
    "John Watson <john.watson1@defra.gov.uk>"
  ],
  "license": "OGL-UK-3.0",
  "type": "module",
  "bugs": {
    "url": "https://github.com/DEFRA/fcp-audit-publisher/issues"
  },
  "homepage": "https://github.com/DEFRA/fcp-audit-publisher#readme",
  "devDependencies": {
    "@vitest/coverage-v8": "4.0.16",
    "eslint": "9.39.2",
    "neostandard": "0.12.2",
    "tsup": "8.5.0",
    "vitest": "4.0.16"
  },
  "dependencies": {
    "joi": "18.1.2"
  },
  "peerDependencies": {
    "@aws-sdk/client-sns": ">=3"
  }
}
